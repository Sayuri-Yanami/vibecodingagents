# 你的模型服务地址。通常填写到 /v1，例如：
# API_BASE_URL=https://your-api.example.com/v1
API_BASE_URL=

# 你的 API Key。不要提交真实密钥。
API_KEY=

# 你的模型名称，即服务商提供的 model id。
API_MODEL=

# 非标准接口可调整下面配置。
API_CHAT_PATH=/chat/completions
API_KEY_HEADER=Authorization
API_KEY_PREFIX=Bearer
API_EXTRA_HEADERS_JSON={}
API_EXTRA_BODY_JSON={}

# 模型参数。
API_TIMEOUT=90
API_TEMPERATURE=0.25
API_MAX_TOKENS=1200

# RAG 参数。
RAG_TOP_K=4
RAG_MIN_SCORE=0.055
HISTORY_TURNS=4

# 客服业务信息。
STORE_NAME=示例优选商城
HUMAN_SERVICE_TEXT=人工客服服务时间为每天 09:00-21:00，请在当前页面留言订单号后四位和问题摘要，我们会尽快处理。

# 网页服务参数。使用 8001，避免与 AI 面试官项目冲突。
WEB_HOST=127.0.0.1
WEB_PORT=8001
