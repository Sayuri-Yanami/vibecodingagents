# 你的模型服务地址。通常填写到 /v1，例如：
# API_BASE_URL=https://your-api.example.com/v1
API_BASE_URL=

# 你的 API Key。不要提交真实密钥。
API_KEY=

# 你的模型名称，例如模型服务商控制台中显示的 model id。
API_MODEL=

# 非标准接口可调整下面三项。
API_CHAT_PATH=/chat/completions
API_KEY_HEADER=Authorization
API_KEY_PREFIX=Bearer

# 可选参数。
API_TIMEOUT=90
API_TEMPERATURE=0.2
API_MAX_TOKENS=1200
API_EXTRA_HEADERS_JSON={}

# RAG 参数。
RAG_TOP_K=4
RAG_MIN_SCORE=0.03

# 网页服务参数。
WEB_HOST=127.0.0.1
WEB_PORT=8000
